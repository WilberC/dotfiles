[branch]
  sort = -committerdate
[column]
  ui = auto
[commit]
  gpgsign = true
  verbose = true
[core]
  excludesfile = ~/.global_gitignore
[diff]
  algorithm = histogram
  colorMoved = default
  mnemonicPrefix = true
  renames = true
  tool = difftastic
[difftool]
  prompt = false
[difftool "difftastic"]
  cmd = difft "$LOCAL" "$REMOTE"
[feature]
  experimental = false
[fetch]
  all = true
  prune = true
  pruneTags = true
[gpg]
  format = ssh
[help]
  autocorrect = prompt
[log]
  follow = true
[include]
  path = ~/.gitconfig-os-specific
[include]
  path = ~/.config/gitconfig/accounts/personal.conf
[include]
  path = ~/.config/gitconfig/work.conf
[init]
  defaultBranch = main
[merge]
  conflictStyle = zdiff3
[pull]
  rebase = true
[push]
  autoSetupRemote = true
  default = simple
  followTags = true
[rebase]
  autoSquash = true
  autoStash = true
  updateRefs = true
[rerere]
  autoUpdate = true
  enabled = true
[tag]
  sort = -version:refname
