#!/usr/bin/env bash
set -euo pipefail

watch_dir="${1:-$PWD}"
exclude_regex="${ZONE_IDENTIFIER_WATCH_EXCLUDE_REGEX:-(^|/)(\.git|node_modules|vendor|\.venv|venv|env|__pycache__|\.mypy_cache|\.pytest_cache|\.ruff_cache|\.cache|\.npm|\.pnpm-store|\.yarn|\.cargo/registry|\.cargo/git|\.rustup|go/pkg/mod)(/|$)|(^|/)\.local/share(/|$)}"

if ! command -v inotifywait >/dev/null 2>&1; then
  echo "Missing dependency: inotifywait"
  echo "Install it with: sudo apt update && sudo apt install -y inotify-tools"
  exit 1
fi

find "$watch_dir" \
  \( \
    -path "$watch_dir/.local/share" -o \
    -path "$watch_dir/.cargo/registry" -o \
    -path "$watch_dir/.cargo/git" -o \
    -path "$watch_dir/go/pkg/mod" -o \
    -type d \( \
      -name '.git' -o \
      -name 'node_modules' -o \
      -name 'vendor' -o \
      -name '.venv' -o \
      -name 'venv' -o \
      -name 'env' -o \
      -name '__pycache__' -o \
      -name '.mypy_cache' -o \
      -name '.pytest_cache' -o \
      -name '.ruff_cache' -o \
      -name '.cache' -o \
      -name '.npm' -o \
      -name '.pnpm-store' -o \
      -name '.yarn' -o \
      -name '.rustup' \
    \) \
  \) -prune -o \
  -type f \( -name '*:Zone.Identifier' -o -name '*Zone.Identifier' \) -exec rm -f -- {} +

echo "Watching $watch_dir for Zone.Identifier files. Press Ctrl+C to stop."
echo "Skipping dependency and cache directories."

inotifywait -m -r \
  -e create -e moved_to -e close_write \
  --exclude "$exclude_regex" \
  --format '%w%f' \
  "$watch_dir" |
while IFS= read -r path; do
  case "$path" in
    *:Zone.Identifier|*Zone.Identifier)
      rm -f -- "$path"
      echo "Removed $path"
      ;;
  esac
done
