#!/usr/bin/env fish

set -g script_path (realpath (status filename))
set -g shared_dir (dirname (dirname (dirname "$script_path")))
set -g skills_dir "$shared_dir/.agents/skills"
set -g target_names Codex Claude
set -g target_dirs "$HOME/.codex/skills" "$HOME/.claude/skills"
set -g target_project_dirs ".agents/skills" ".claude/skills"

function c
    set_color $argv[1]
    printf '%s' $argv[2..-1]
    set_color normal
end

function fail
    c red "sync-skills: " >&2
    echo "$argv" >&2
    exit 1
end

function add_selected_index --argument-names value max
    if not string match -rq '^[0-9]+$' -- "$value"
        fail "invalid selection: $value"
    end

    if test "$value" -lt 1 -o "$value" -gt "$max"
        fail "selection out of range: $value"
    end

    if not contains -- "$value" $selected_indexes
        set -ga selected_indexes "$value"
    end
end

function add_selected_target --argument-names token
    if string match -rq '^[0-9]+$' -- "$token"
        add_selected_index "$token" (count $target_names)
        return
    end

    set -l normalized_token (string lower -- "$token")

    for index in (seq 1 (count $target_names))
        if test "$normalized_token" = (string lower -- "$target_names[$index]")
            add_selected_index "$index" (count $target_names)
            return
        end
    end

    fail "unknown target: $token"
end

function pretty_path --argument-names path
    string replace -- "$HOME" '~' "$path"
end

function resolved_path --argument-names path
    readlink -f "$path" 2>/dev/null
end

function sync_selected_skills_to_target --argument-names target target_dir
    mkdir -p "$target_dir"

    c brblue "Creating $target links:"
    echo ""

    for skill in $selected_skills
        set -l source_path "$skills_dir/$skill"
        set -l link_path "$target_dir/$skill"

        if test -L "$link_path"
            set -l current_target (readlink "$link_path")

            if test "$link_path" -ef "$source_path"
                printf "  %s %s %s %s\n" (c brblack '=') (c cyan (pretty_path "$link_path")) (c brblack '->') (pretty_path "$source_path")
                continue
            end

            if test (resolved_path "$link_path/SKILL.md") = (resolved_path "$source_path/SKILL.md")
                rm "$link_path"
                ln -s "$source_path" "$link_path"
                printf "  %s %s %s %s %s\n" (c yellow '~') (c cyan (pretty_path "$link_path")) (c brblack '->') (pretty_path "$source_path") (c brblack "(refreshed from $current_target)")
                continue
            end

            fail "link already exists with different target: "(pretty_path "$link_path")" -> $current_target"
        end

        if test -e "$link_path"
            if test (resolved_path "$link_path/SKILL.md") = (resolved_path "$source_path/SKILL.md")
                fail "path already exists and is not a symlinked skill folder: "(pretty_path "$link_path")". Move it aside, then rerun sync-skills so the whole skill folder can be linked."
            end

            fail "path already exists and is not a symlink: "(pretty_path "$link_path")
        end

        ln -s "$source_path" "$link_path"
        printf "  %s %s %s %s\n" (c green '+') (c cyan (pretty_path "$link_path")) (c brblack '->') (pretty_path "$source_path")
    end
end

function print_paths
    c brblue "Skill paths:"
    echo ""
    printf "  %s %s\n" (c brblack 'source:') (c cyan (pretty_path "$skills_dir"))

    for index in (seq 1 (count $target_names))
        set -l target "$target_names[$index]"
        set -l target_dir "$target_dirs[$index]"
        set -l project_dir "$target_project_dirs[$index]"

        printf "  %s %s %s %s\n" (c brblack "$target:") (c cyan (pretty_path "$target_dir")) (c brblack 'project') (c cyan "$project_dir")
    end
end

function select_skills_with_fzf
    set -g selected_skills (printf '%s\n' $skills | fzf \
        --multi \
        --prompt 'Skills> ' \
        --header 'Space: select  Ctrl-A: all  Ctrl-D: none  Enter: confirm' \
        --bind 'space:toggle,ctrl-a:select-all,ctrl-d:deselect-all' \
        --marker '* ' \
        --height 40% \
        --layout reverse \
        --border)
end

function select_skills_with_prompt
    c brblue "Skills in "
    c cyan (pretty_path "$skills_dir")
    echo ":"

    set -l index 1
    for skill in $skills
        printf "  %s %s\n" (c yellow "$index)") "$skill"
        set index (math $index + 1)
    end

    echo ""
    read --prompt-str "Select skills (1, 1 3, 1-3, all): " selection

    set -g selected_indexes
    set -l skill_count (count $skills)
    set -l normalized_selection (string lower -- (string trim -- "$selection"))

    if test -z "$normalized_selection"
        fail "no selection provided"
    end

    if test "$normalized_selection" = all -o "$normalized_selection" = '*'
        set selected_indexes (seq 1 $skill_count)
    else
        set -l tokens (string replace -a ',' ' ' -- "$normalized_selection" | string split ' ')

        for token in $tokens
            if test -z "$token"
                continue
            end

            if string match -rq '^[0-9]+-[0-9]+$' -- "$token"
                set -l bounds (string split '-' -- "$token")
                set -l start $bounds[1]
                set -l end $bounds[2]

                if test "$start" -gt "$end"
                    fail "invalid range: $token"
                end

                for number in (seq $start $end)
                    add_selected_index "$number" "$skill_count"
                end
            else
                add_selected_index "$token" "$skill_count"
            end
        end
    end

    set -g selected_skills

    for selected_index in $selected_indexes
        set -ga selected_skills "$skills[$selected_index]"
    end
end

function select_targets_with_fzf
    set -l target_options

    for index in (seq 1 (count $target_names))
        set -l target "$target_names[$index]"
        set -l target_dir "$target_dirs[$index]"

        set -a target_options "$target ("(pretty_path "$target_dir")")"
    end

    set -l selected_target_options (printf '%s\n' $target_options | fzf \
        --multi \
        --prompt 'Targets> ' \
        --header 'Space: select  Ctrl-A: all  Ctrl-D: none  Enter: confirm' \
        --bind 'space:toggle,ctrl-a:select-all,ctrl-d:deselect-all' \
        --marker '* ' \
        --height 40% \
        --layout reverse \
        --border)

    set -g selected_targets

    for option in $selected_target_options
        set -ga selected_targets (string replace -r ' \(.+\)$' '' -- "$option")
    end
end

function select_targets_with_prompt
    c brblue "Targets:"
    echo ""

    for index in (seq 1 (count $target_names))
        set -l target "$target_names[$index]"
        set -l target_dir "$target_dirs[$index]"
        set -l project_dir "$target_project_dirs[$index]"

        printf "  %s %s %s %s %s %s\n" (c yellow "$index)") "$target" (c brblack 'global') (c cyan (pretty_path "$target_dir")) (c brblack 'project') (c cyan "$project_dir")
    end

    echo ""
    read --prompt-str "Select targets (1, 2, Codex, Claude, all): " selection

    set -g selected_indexes
    set -l normalized_selection (string lower -- (string trim -- "$selection"))

    if test -z "$normalized_selection"
        fail "no targets selected"
    end

    if test "$normalized_selection" = all -o "$normalized_selection" = '*'
        set selected_indexes (seq 1 (count $target_names))
    else
        set -l tokens (string replace -a ',' ' ' -- "$normalized_selection" | string split ' ')

        for token in $tokens
            if test -z "$token"
                continue
            end

            add_selected_target "$token"
        end
    end

    set -g selected_targets

    for selected_index in $selected_indexes
        set -ga selected_targets "$target_names[$selected_index]"
    end
end

if not test -d "$skills_dir"
    fail "skills directory not found: $skills_dir"
end

set -g skills

for skill_path in "$skills_dir"/*
    if test -d "$skill_path"
        set -ga skills (basename "$skill_path")
    end
end

set skills (printf '%s\n' $skills | sort)

if test (count $skills) -eq 0
    c yellow "No skills found in "
    c cyan (pretty_path "$skills_dir")
    echo ""
    exit 0
end

set -g selected_skills

if command -q fzf; and isatty stdin
    select_skills_with_fzf

    if test $status -ne 0
        fail "selection cancelled"
    end
else
    select_skills_with_prompt
end

if test (count $selected_skills) -eq 0
    fail "no selection provided"
end

echo ""
printf "%s %s\n" (c brblack 'Selected skills:') (c green (string join ', ' $selected_skills))
echo ""
print_paths

set -g selected_targets

if command -q fzf; and isatty stdin
    select_targets_with_fzf

    if test $status -ne 0
        fail "target selection cancelled"
    end
else
    select_targets_with_prompt
end

if test (count $selected_targets) -eq 0
    fail "no targets selected"
end

echo ""
printf "%s %s\n" (c brblack 'Selected targets:') (c green (string join ', ' $selected_targets))
echo ""

for target in $selected_targets
    set -l target_index (contains --index -- "$target" $target_names)
    sync_selected_skills_to_target "$target" "$target_dirs[$target_index]"
end
